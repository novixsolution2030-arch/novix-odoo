<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nawaem_product_form" model="ir.ui.view">
        <field name="name">nawaem.product.form</field>
        <field name="model">nawaem.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم المنتج..."/></h1>
                    </div>
                    <group>
                        <group string="المعلومات الأساسية">
                            <field name="provider_id"/>
                            <field name="category_id"/>
                            <field name="price"/>
                            <field name="promo_video_url" widget="url"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="تفاصيل الشحن والدفع">
                            <field name="shipping_scope" widget="radio"/>
                            <field name="allowed_state_ids" widget="many2many_tags" invisible="shipping_scope != 'specific'" placeholder="اختر الولايات..."/>
                            <field name="delivery_fee"/>
                            <field name="payment_methods"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="الصور الإلزامية">
                            <group>
                                <group>
                                    <field name="image_main" widget="image" class="oe_avatar"/>
                                    <field name="image_sub_1" widget="image" class="oe_avatar"/>
                                </group>
                                <group>
                                    <field name="image_sub_2" widget="image" class="oe_avatar"/>
                                    <field name="image_sub_3" widget="image" class="oe_avatar"/>
                                </group>
                            </group>
                        </page>
                        <page string="الوصف">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nawaem_product_tree" model="ir.ui.view">
        <field name="name">nawaem.product.tree</field>
        <field name="model">nawaem.product</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="provider_id"/>
                <field name="category_id"/>
                <field name="price"/>
                <field name="shipping_scope"/>
                <field name="delivery_fee"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
</odoo>