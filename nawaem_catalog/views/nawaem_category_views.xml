<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nawaem_category_form" model="ir.ui.view">
        <field name="name">nawaem.category.form</field>
        <field name="model">nawaem.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم القسم..."/></h1>
                    </div>
                    <group>
                        <field name="category_type" widget="radio"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nawaem_category_tree" model="ir.ui.view">
        <field name="name">nawaem.category.tree</field>
        <field name="model">nawaem.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category_type"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
</odoo>
