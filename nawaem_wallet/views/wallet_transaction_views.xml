<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wallet_transaction_form" model="ir.ui.view">
        <field name="name">nawaem.wallet.transaction.form</field>
        <field name="model">nawaem.wallet.transaction</field>
        <field name="arch" type="xml">
            <form string="حركة مالية">
                <header>
                    <button name="action_confirm" string="تأكيد" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="إلغاء" type="object" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="transaction_type" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="البيان">
                            <field name="description" readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_wallet_transaction_tree" model="ir.ui.view">
        <field name="name">nawaem.wallet.transaction.tree</field>
        <field name="model">nawaem.wallet.transaction</field>
        <field name="arch" type="xml">
            <tree string="الحركات المالية" decoration-success="transaction_type=='deposit'" decoration-danger="transaction_type in ('commission', 'transfer')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="transaction_type"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="action_wallet_transaction" model="ir.actions.act_window">
        <field name="name">حركات المحافظ</field>
        <field name="res_model">nawaem.wallet.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>

   
    <menuitem id="menu_nawaem_wallet" name="المحافظ المالية" parent="nawaem_core.menu_nawaem_root" action="action_wallet_transaction" sequence="10"/>
</odoo>
