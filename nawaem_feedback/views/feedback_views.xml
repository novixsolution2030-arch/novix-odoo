<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nawaem_feedback_tree" model="ir.ui.view">
        <field name="name">nawaem.feedback.tree</field>
        <field name="model">nawaem.feedback</field>
        <field name="arch" type="xml">
            <tree decoration-info="state=='new'" decoration-warning="state=='reviewed'" decoration-success="state=='resolved'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="feedback_type"/>
                <field name="create_date"/>
                <field name="state" widget="badge" 
                       decoration-info="state=='new'" 
                       decoration-warning="state=='reviewed'" 
                       decoration-success="state=='resolved'"/>
            </tree>
        </field>
    </record>

    <record id="view_nawaem_feedback_form" model="ir.ui.view">
        <field name="name">nawaem.feedback.form</field>
        <field name="model">nawaem.feedback</field>
        <field name="arch" type="xml">
            <form>
              <header>
    <button name="action_review" string="قيد المراجعة" type="object" invisible="state != 'new'" class="oe_highlight"/>
    <button name="action_resolve" string="تم الحل" type="object" invisible="state != 'reviewed'" class="oe_highlight"/>
    <button name="action_close" string="إغلاق" type="object" invisible="state not in ('resolved', 'reviewed')"/>
    <field name="state" widget="statusbar" statusbar_visible="new,reviewed,resolved,closed"/>
</header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="feedback_type"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="attached_image" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="نص الرسالة">
                            <field name="message"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_nawaem_feedback" model="ir.actions.act_window">
        <field name="name">الشكاوى والمقترحات</field>
        <field name="res_model">nawaem.feedback</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>