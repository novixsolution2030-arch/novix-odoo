<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wallet_transaction_form" model="ir.ui.view">
        <field name="name">wallet.transaction.form</field>
        <field name="model">wallet.transaction</field>
        <field name="arch" type="xml">
            <form string="Wallet Transaction">
                <header>
                    <button name="action_post" string="Post Transaction" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-danger" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Transaction Details">
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="transaction_type" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'" widget="monetary"/>
                            <field name="source" readonly="state != 'draft'"/>
                        </group>
                        <group string="References">
                            <field name="description" readonly="state != 'draft'"/>
                            <field name="order_id" readonly="state != 'draft'" invisible="source not in ('order', 'commission')"/>
                            <field name="move_id"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_wallet_transaction_tree" model="ir.ui.view">
        <field name="name">wallet.transaction.tree</field>
        <field name="model">wallet.transaction</field>
        <field name="arch" type="xml">
            <tree string="Wallet Transactions" decoration-success="transaction_type == 'credit'" decoration-danger="transaction_type == 'debit'">
                <field name="name"/>
                <field name="create_date"/>
                <field name="partner_id"/>
                <field name="description"/>
                <field name="source"/>
                <field name="transaction_type"/>
                <field name="amount" sum="Total Amount"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-muted="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <record id="action_wallet_transactions" model="ir.actions.act_window">
        <field name="name">Wallet Transactions</field>
        <field name="res_model">wallet.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>