<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_wallet" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.wallet</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(action_wallet_transactions)d" 
                        type="action" 
                        class="oe_stat_button" 
                        icon="fa-money" 
                        context="{'search_default_partner_id': id, 'default_partner_id': id}">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="wallet_balance" widget="monetary"/>
                        </span>
                        <span class="o_stat_text">Wallet</span>
                    </div>
                </button>
            </xpath>
            
        </field>
    </record>
</odoo>