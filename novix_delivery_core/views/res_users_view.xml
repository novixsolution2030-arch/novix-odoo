<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_novix" model="ir.ui.view">
        <field name="name">res.users.form.inherit.novix</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <group>
                    <field name="user_type" widget="radio" options="{'horizontal': true}"/>
                    <field name="is_available" invisible="user_type != 'driver'"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>