<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_delivery" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.delivery</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
                    <xpath expr="//form" position="inside">

                <div class="app_settings_block" data-string="Delivery Platform" string="Delivery Platform" data-key="novix_delivery_core">
                    <h2>Platform Operational Settings</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_system_commission"/>
                                <div class="text-muted">
                                    Global commission percentage deducted from merchants/drivers
                                </div>
                                <field name="delivery_system_commission" class="w-25"/> %
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_base_km_price"/>
                                <div class="text-muted">
                                    Standard cost per kilometer for base calculations
                                </div>
                                <field name="delivery_base_km_price" class="w-25"/> SAR
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_max_distance"/>
                                <div class="text-muted">
                                    Limit the reach of delivery orders
                                </div>
                                <field name="delivery_max_distance" class="w-25"/> KM
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_bidding_time"/>
                                <div class="text-muted">
                                    Time window for active bids before expiry
                                </div>
                                <field name="delivery_bidding_time" class="w-25"/> Sec
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_min_wallet_balance"/>
                                <div class="text-muted">
                                     Minimum Wallet Balance for Drivers
                                </div>
                                <field name="delivery_min_wallet_balance" class="w-25"/> Sec
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="delivery_agent_commission"/>
                                <div class="text-muted">
                                    Agent Recharge Commission (%)
                                </div>
                                <field name="delivery_agent_commission" class="w-25"/> Sec
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="taxi_base_fee"/>
                                <div class="text-muted">
                                    Taxi Base Fee
                                </div>
                                <field name="taxi_base_fee" class="w-25"/> Sec
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="taxi_km_price"/>
                                <div class="text-muted">
                                    Taxi KM price
                                </div>
                                <field name="taxi_km_price" class="w-25"/> Sec
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="delivery_config_settings_action" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'novix_delivery_core', 'bin_size': False}</field>
    </record>

    <menuitem id="menu_delivery_root" name="Delivery Platform" sequence="10" web_icon="novix_delivery_core,static/description/icon.png"/>
    <menuitem id="menu_delivery_configuration" name="Configuration" parent="menu_delivery_root" sequence="100"/>
    <menuitem id="menu_delivery_settings" name="Settings" parent="menu_delivery_configuration" action="delivery_config_settings_action" sequence="10"/>
    <menuitem id="menu_delivery_finance" name="Financial" parent="menu_delivery_root"  sequence="10"/>

</odoo>